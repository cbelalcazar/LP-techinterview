generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  description String
  category    String
  price       Float
  stock       Int
  weight_kg   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]

  @@index([name])
  @@index([category])
}

model Transaction {
  id        String   @id @default(uuid())
  productId String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
